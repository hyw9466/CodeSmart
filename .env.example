# =============================================================================
# 环境变量配置示例
# 复制此文件为 .env 并填入真实 API Key 即可运行
# =============================================================================

# ------------------------------------------------------------------------------
# 嵌入模型配置（Embedding）
# ------------------------------------------------------------------------------
# 提供商可选值：jina | dashscope | openai
# - jina      : Jina AI（海外服务，国内需代理/加速器）
# - dashscope : 阿里云 DashScope（国内直连，无需代理，推荐）
# - openai    : OpenAI 或任意 OpenAI 兼容端点（如硅基流动、OpenRouter）
EMBEDDING_PROVIDER=dashscope

# 嵌入模型名称（根据提供商填写）
# DashScope 可选: text-embedding-v3, text-embedding-v2, text-embedding-v1
# Jina AI 可选: jina-embeddings-v3, jina-embeddings-v2-base-zh
EMBEDDING_MODEL=text-embedding-v3

# 嵌入模型 API Key
# 当 PROVIDER=dashscope 时，填 DashScope 的 API Key
# 当 PROVIDER=openai 时，填 OpenAI 或兼容服务的 API Key
EMBEDDING_API_KEY=your-dashscope-api-key-here

# 嵌入模型 API 基础地址（OpenAI 兼容格式需要）
# DashScope: https://dashscope.aliyuncs.com/compatible-mode/v1
# 硅基流动: https://api.siliconflow.cn/v1
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ------------------------------------------------------------------------------
# 兼容旧版 Jina 配置（如仍使用 Jina 可单独配置）
# ------------------------------------------------------------------------------
# JINA_API_KEY=your-jina-api-key-here

# ------------------------------------------------------------------------------
# 聊天模型配置（LLM）
# ------------------------------------------------------------------------------
# 默认使用阿里云 DashScope，国内直连
LLM_MODEL=qwen3.6-plus
DASHSCOPE_API_KEY=your-dashscope-api-key-here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ------------------------------------------------------------------------------
# 可选：并发控制
# ------------------------------------------------------------------------------
# EMBEDDING_CONCURRENCY=3
